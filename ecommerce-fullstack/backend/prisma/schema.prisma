datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductStatus {
  ON_SHELF
  OFF_SHELF
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  addresses UserAddress[]
  orders    Order[]
}

model UserAddress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  receiverName  String
  phone         String
  province      String
  city          String
  district      String
  detailAddress String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  parent    Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  products  ProductSpu[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSpu {
  id          String        @id @default(uuid())
  name        String
  spuNo       String        @unique
  description String?
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  status      ProductStatus @default(OFF_SHELF)
  skus        ProductSku[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductSku {
  id         String     @id @default(uuid())
  spuId      String
  spu        ProductSpu @relation(fields: [spuId], references: [id])
  skuNo      String     @unique
  price      Decimal
  stock      Int
  specs      Json
  coverImage String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Decimal
  status          OrderStatus @default(PENDING)
  trackingNumber  String?
  courierCompany  String?
  addressSnapshot Json
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  skuId     String
  spuName   String
  skuSpecs  Json
  price     Decimal
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
